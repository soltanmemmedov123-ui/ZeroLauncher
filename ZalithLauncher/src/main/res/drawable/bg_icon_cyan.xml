<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2638BDF8" />
            <corners android:radius="7dp" />
            <stroke android:width="1dp" android:color="#3338BDF8" />
        </shape>
    </item>
    <item android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#12FFFFFF" android:endColor="#00000000" />
            <corners android:radius="7dp" />
            <size android:height="5dp" />
        </shape>
    </item>
</layer-list>
