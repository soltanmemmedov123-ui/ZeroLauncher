<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main glass base: rgba(16,16,38,0.68) = #AD101026 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#AD101026" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="#17FFFFFF" />
        </shape>
    </item>
    <!-- Top shine stripe — HTML ::before: transparent → #38FFFFFF → transparent
         inset 8% from each side, height 1dp, at top -->
    <item
        android:top="0dp"
        android:bottom="0dp"
        android:left="16dp"
        android:right="16dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#38FFFFFF"
                android:endColor="#00FFFFFF" />
            <size android:height="1dp" />
        </shape>
    </item>
    <!-- Inner top glow: inset 0 1px 0 rgba(255,255,255,0.06) -->
    <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#0FFFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="20dp" />
            <size android:height="4dp" />
        </shape>
    </item>
</layer-list>
