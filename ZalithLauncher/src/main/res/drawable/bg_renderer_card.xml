<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true" android:drawable="@drawable/bg_renderer_card_active" />
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1538BDF8" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#2538BDF8" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#AD101026" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#17FFFFFF" />
        </shape>
    </item>
</selector>
