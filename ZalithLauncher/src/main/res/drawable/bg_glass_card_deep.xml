<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#C70A0A1A" />
            <stroke android:width="0dp" android:color="#00000000" />
        </shape>
    </item>
    <!-- Bottom border line -->
    <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#17FFFFFF"
                android:endColor="#00FFFFFF" />
            <size android:height="1dp" />
        </shape>
    </item>
</layer-list>
