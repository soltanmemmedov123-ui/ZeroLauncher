<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_network_monitor.xml
    Network Packet Monitor – ZeroLauncher DevTools Tab 2

    Layout regions (top → bottom):
      1. Control Bar   – Start/Stop proxy, status, port selector
      2. Filter Bar    – EditText to filter by packet name
      3. Overflow Warn – Amber warning bar (GONE unless ring-buffer overflow)
      4. Packet List   – RecyclerView (weight=1, takes all remaining space)
      5. Empty Hint    – Centered text overlay when list is empty
      6. Detail Panel  – Collapsible bottom card for selected-packet detail
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/transparent">

    <!-- ══════════════════════════════════════════════════════════════════
         1.  CONTROL BAR
         ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/zl_bg_surface"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <!-- Row 1: Start/Stop button + Status text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btn_proxy_start_stop"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="▶  START PROXY"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:background="@drawable/bg_launch_btn"
                android:paddingHorizontal="14dp"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/tv_proxy_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Not running"
                android:textColor="@color/zl_text_muted"
                android:textSize="11sp"
                android:ellipsize="end"
                android:maxLines="1" />

        </LinearLayout>

        <!-- Row 2: Port label + Change port button + Clear button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tv_proxy_port_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Port: 25566"
                android:textColor="@color/zl_text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <!-- Gear / change port -->
            <Button
                android:id="@+id/btn_proxy_change_port"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="⚙ PORT"
                android:textColor="@color/zl_text_secondary"
                android:textSize="9sp"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="10dp"
                android:stateListAnimator="@null"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_clear_packets"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="✕ CLEAR"
                android:textColor="@color/zl_text_secondary"
                android:textSize="9sp"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="10dp"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/zl_bg_card" />

    <!-- ══════════════════════════════════════════════════════════════════
         2.  FILTER BAR
         ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/zl_bg_surface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/et_packet_filter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Filter by packet name or ID…"
            android:textColor="@color/zl_text_primary"
            android:textColorHint="@color/zl_text_hint"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="@null"
            android:maxLines="1"
            android:inputType="text"
            android:imeOptions="actionDone" />

        <Button
            android:id="@+id/btn_pause_scroll"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="⏸  PAUSE"
            android:textColor="@color/zl_text_secondary"
            android:textSize="9sp"
            android:background="@drawable/bg_menu_item"
            android:paddingHorizontal="10dp"
            android:stateListAnimator="@null"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/zl_bg_card" />

    <!-- ══════════════════════════════════════════════════════════════════
         3.  OVERFLOW WARNING  (GONE by default)
         ══════════════════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tv_overflow_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠ Ring buffer full – oldest packets discarded"
        android:textColor="@color/zl_amber"
        android:textSize="10sp"
        android:gravity="center"
        android:paddingVertical="4dp"
        android:background="#22FBBF24"
        android:visibility="gone" />

    <!-- ══════════════════════════════════════════════════════════════════
         4.  PACKET LIST  +  5. EMPTY HINT  (overlapping FrameLayout)
         ══════════════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_packets"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="4dp"
            android:overScrollMode="ifContentScrolls" />

        <TextView
            android:id="@+id/tv_empty_hint"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Proxy not running. Tap Start to begin capturing."
            android:textColor="@color/zl_text_muted"
            android:textSize="12sp"
            android:paddingHorizontal="32dp"
            android:visibility="visible" />

    </FrameLayout>

    <!-- ══════════════════════════════════════════════════════════════════
         6.  DETAIL PANEL  (GONE until a packet is tapped)
         ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/detail_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/zl_bg_surface"
        android:visibility="gone">

        <!-- Detail panel divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="@color/zl_cyan" />

        <!-- Header row: title + close button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PACKET DETAIL"
                android:textColor="@color/zl_cyan"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <Button
                android:id="@+id/btn_copy_hex"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="COPY HEX"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold"
                android:background="@drawable/bg_launch_btn"
                android:paddingHorizontal="10dp"
                android:stateListAnimator="@null"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_close_detail"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="✕"
                android:textColor="@color/zl_text_secondary"
                android:textSize="10sp"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="10dp"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- Fields grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingBottom="6dp">

            <!-- Left column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIMESTAMP"
                    android:textColor="@color/zl_text_muted"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tv_detail_timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/zl_text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATE"
                    android:textColor="@color/zl_text_muted"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tv_detail_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/zl_purple"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <!-- Right column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PACKET ID"
                    android:textColor="@color/zl_text_muted"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tv_detail_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/zl_text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LENGTH"
                    android:textColor="@color/zl_text_muted"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tv_detail_length"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/zl_text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </LinearLayout>

        <!-- Hex dump label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HEX DUMP (first 64 bytes)"
            android:textColor="@color/zl_text_muted"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="2dp" />

        <!-- Hex dump scrollable box -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_detail_hex"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/zl_green"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:background="@color/zl_bg_card"
                android:padding="8dp"
                android:minWidth="0dp" />

        </HorizontalScrollView>

    </LinearLayout>

</LinearLayout>
