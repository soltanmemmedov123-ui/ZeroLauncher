<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass_card_deep"
    android:padding="20dp">

    <TextView
        android:id="@+id/tip_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/zl_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tip_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/zl_text_secondary"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.4" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/tip_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_slate"
            android:textColor="@color/zl_text_secondary"
            android:textSize="12sp"
            android:stateListAnimator="@null"
            android:text="@string/generic_cancel" />

        <Button
            android:id="@+id/tip_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_cyan"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:stateListAnimator="@null"
            android:text="@string/generic_ok" />
    </LinearLayout>
</LinearLayout>
