<?xml version="1.0" encoding="utf-8"?>
<!--
    item_crash_record.xml
    One row in the crash history RecyclerView / dynamic LinearLayout.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1C2E"
    android:clickable="true"
    android:focusable="true"
    android:padding="12dp"
    android:layout_marginBottom="6dp">

    <!-- Row 1: time + short exception name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_item_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="May 25, 14:32"
            android:textColor="#6B7280"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/tv_item_exception"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NullPointerException"
            android:textColor="#F87171"
            android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_item_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Fixed"
            android:textColor="#4ADE80"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Row 2: suspect mod chip + fix label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_item_mod"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="● Sodium"
            android:textColor="#06B6D4"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_item_fix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="disable mod"
            android:textColor="#9CA3AF"
            android:textSize="10sp"
            android:background="#2D2F4A"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp" />
    </LinearLayout>

</LinearLayout>
