<?xml version="1.0" encoding="utf-8"?>
<!-- Zero Launcher - Downloads Page -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Search + Filter card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <!-- Tab bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button android:id="@+id/tab_mod"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginEnd="4dp" android:text="Mod"
                    android:textSize="9sp" android:textStyle="bold" android:textColor="@color/zl_cyan"
                    android:background="@drawable/bg_tab_btn" android:stateListAnimator="@null"
                    tools:selected="true" android:paddingTop="6dp" android:paddingBottom="6dp" />

                <Button android:id="@+id/tab_resource"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginEnd="4dp" android:text="Resource Pack"
                    android:textSize="9sp" android:textStyle="bold" android:textColor="@color/zl_text_secondary"
                    android:background="@drawable/bg_tab_btn" android:stateListAnimator="@null"
                    tools:selected="false" android:paddingTop="6dp" android:paddingBottom="6dp" />

                <Button android:id="@+id/tab_world"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginEnd="4dp" android:text="World"
                    android:textSize="9sp" android:textStyle="bold" android:textColor="@color/zl_text_secondary"
                    android:background="@drawable/bg_tab_btn" android:stateListAnimator="@null"
                    tools:selected="false" android:paddingTop="6dp" android:paddingBottom="6dp" />

                <Button android:id="@+id/tab_shader"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Shader Pack"
                    android:textSize="9sp" android:textStyle="bold" android:textColor="@color/zl_text_secondary"
                    android:background="@drawable/bg_tab_btn" android:stateListAnimator="@null"
                    tools:selected="false" android:paddingTop="6dp" android:paddingBottom="6dp" />
            </LinearLayout>

            <!-- Search bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_bar"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="6dp" android:paddingBottom="6dp"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:layout_width="12dp" android:layout_height="12dp"
                    android:src="@drawable/ic_search"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="Search" />

                <EditText android:id="@+id/search_downloads"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:hint="Search downloads…" android:textColorHint="@color/zl_text_muted"
                    android:textColor="@color/zl_text_primary" android:textSize="10sp"
                    android:background="@null" android:padding="0dp"
                    android:inputType="text" android:imeOptions="actionSearch"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Filter chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/chip_all"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="All" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="@color/zl_cyan"
                        android:background="@drawable/bg_chip" tools:selected="true"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" />

                    <TextView android:id="@+id/chip_121x"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1.21.x" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="@color/zl_text_secondary"
                        android:background="@drawable/bg_chip" tools:selected="false"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" />

                    <TextView android:id="@+id/chip_fabric"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fabric" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="@color/zl_text_secondary"
                        android:background="@drawable/bg_chip" tools:selected="false"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" />

                    <TextView android:id="@+id/chip_forge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Forge" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="@color/zl_text_secondary"
                        android:background="@drawable/bg_chip" tools:selected="false"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" />

                    <TextView android:id="@+id/chip_popular"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Popular" android:textSize="9sp" android:textStyle="bold"
                        android:textColor="@color/zl_text_secondary"
                        android:background="@drawable/bg_chip" tools:selected="false"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:clickable="true" android:focusable="true" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Download cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp">

            <!-- Sodium card -->
            <LinearLayout
                android:id="@+id/dl_sodium"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/bg_dl_card"
                android:padding="10dp" android:layout_marginBottom="5dp"
                android:clickable="true" android:focusable="true">

                <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                    android:background="@drawable/bg_dl_icon_green"
                    android:layout_marginEnd="8dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:layout_gravity="center" android:src="@drawable/ic_dl_sodium"
                        android:contentDescription="Sodium" />
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PERFORMANCE MOD" android:textColor="@color/zl_text_muted"
                        android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.08" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sodium" android:textColor="@color/zl_text_primary"
                        android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Modern rendering engine, greatly improving frame rates."
                        android:textColor="@color/zl_text_secondary" android:textSize="9sp"
                        android:lineSpacingMultiplier="1.3" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="3dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1.21.4" android:textColor="@color/zl_text_muted" android:textSize="8sp"
                            android:textStyle="bold" android:background="@drawable/bg_dl_meta_chip"
                            android:paddingStart="6dp" android:paddingEnd="6dp"
                            android:paddingTop="2dp" android:paddingBottom="2dp"
                            android:layout_marginEnd="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fabric" android:textColor="@color/zl_text_muted" android:textSize="8sp"
                            android:textStyle="bold" android:background="@drawable/bg_dl_meta_chip"
                            android:paddingStart="6dp" android:paddingEnd="6dp"
                            android:paddingTop="2dp" android:paddingBottom="2dp"
                            android:layout_marginEnd="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="4.8M ↓" android:textColor="@color/zl_text_muted" android:textSize="8sp"
                            android:textStyle="bold" android:background="@drawable/bg_dl_meta_chip"
                            android:paddingStart="6dp" android:paddingEnd="6dp"
                            android:paddingTop="2dp" android:paddingBottom="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <Button android:id="@+id/btn_get_sodium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Get" android:textSize="9sp" android:textStyle="bold"
                    android:textColor="@color/zl_cyan" android:background="@drawable/bg_dl_get_btn"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:stateListAnimator="@null" android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Lithium card -->
            <LinearLayout
                android:id="@+id/dl_lithium"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/bg_dl_card"
                android:padding="10dp" android:layout_marginBottom="5dp"
                android:clickable="true" android:focusable="true">

                <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                    android:background="@drawable/bg_dl_icon_cyan"
                    android:layout_marginEnd="8dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:layout_gravity="center" android:src="@drawable/ic_dl_lithium"
                        android:contentDescription="Lithium" />
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="UTILITY MOD" android:textColor="@color/zl_text_muted"
                        android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.08" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lithium" android:textColor="@color/zl_text_primary"
                        android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="General-purpose optimization for server-side performance."
                        android:textColor="@color/zl_text_secondary" android:textSize="9sp"
                        android:lineSpacingMultiplier="1.3" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="3dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1.21.4" android:textColor="@color/zl_text_muted" android:textSize="8sp"
                            android:textStyle="bold" android:background="@drawable/bg_dl_meta_chip"
                            android:paddingStart="6dp" android:paddingEnd="6dp"
                            android:paddingTop="2dp" android:paddingBottom="2dp"
                            android:layout_marginEnd="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fabric" android:textColor="@color/zl_text_muted" android:textSize="8sp"
                            android:textStyle="bold" android:background="@drawable/bg_dl_meta_chip"
                            android:paddingStart="6dp" android:paddingEnd="6dp"
                            android:paddingTop="2dp" android:paddingBottom="2dp"
                            android:layout_marginEnd="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="2.1M ↓" android:textColor="@color/zl_text_muted" android:textSize="8sp"
                            android:textStyle="bold" android:background="@drawable/bg_dl_meta_chip"
                            android:paddingStart="6dp" android:paddingEnd="6dp"
                            android:paddingTop="2dp" android:paddingBottom="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <Button android:id="@+id/btn_get_lithium"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Get" android:textSize="9sp" android:textStyle="bold"
                    android:textColor="@color/zl_cyan" android:background="@drawable/bg_dl_get_btn"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:stateListAnimator="@null" android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Iris Shaders card -->
            <LinearLayout
                android:id="@+id/dl_iris"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/bg_dl_card"
                android:padding="10dp"
                android:clickable="true" android:focusable="true">

                <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                    android:background="@drawable/bg_dl_icon_purple"
                    android:layout_marginEnd="8dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:layout_gravity="center" android:src="@drawable/ic_dl_iris"
                        android:contentDescription="Iris Shaders" />
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HUD MOD" android:textColor="@color/zl_text_muted"
                        android:textSize="8sp" android:textStyle="bold" android:letterSpacing="0.08" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Iris Shaders" android:textColor="@color/zl_text_primary"
                        android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Compatible with OptiFine shaders, built for Fabric and Sodium."
                        android:textColor="@color/zl_text_secondary" android:textSize="9sp"
                        android:lineSpacingMultiplier="1.3" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="3dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1.21.4" android:textColor="@color/zl_text_muted" android:textSize="8sp"
                            android:textStyle="bold" android:background="@drawable/bg_dl_meta_chip"
                            android:paddingStart="6dp" android:paddingEnd="6dp"
                            android:paddingTop="2dp" android:paddingBottom="2dp"
                            android:layout_marginEnd="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fabric" android:textColor="@color/zl_text_muted" android:textSize="8sp"
                            android:textStyle="bold" android:background="@drawable/bg_dl_meta_chip"
                            android:paddingStart="6dp" android:paddingEnd="6dp"
                            android:paddingTop="2dp" android:paddingBottom="2dp"
                            android:layout_marginEnd="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="3.5M ↓" android:textColor="@color/zl_text_muted" android:textSize="8sp"
                            android:textStyle="bold" android:background="@drawable/bg_dl_meta_chip"
                            android:paddingStart="6dp" android:paddingEnd="6dp"
                            android:paddingTop="2dp" android:paddingBottom="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <Button android:id="@+id/btn_get_iris"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Get" android:textSize="9sp" android:textStyle="bold"
                    android:textColor="@color/zl_cyan" android:background="@drawable/bg_dl_get_btn"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:stateListAnimator="@null" android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
