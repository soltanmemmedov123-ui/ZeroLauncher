<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_dev_tools.xml  (modified – adds "Crashes" tab)
    Compared to original:
      • tab_crashes TextView added as 4th segment in the tab row.
      • Two additional separator Views added.
    Everything else is unchanged.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_launcher">

    <!-- ── Toolbar row (unchanged) ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <FrameLayout
            android:id="@+id/dev_tools_back"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_nav_icon"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_right"
                android:rotation="180"
                android:imageTintList="@color/zl_cyan"
                android:contentDescription="Back" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer Tools"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ZERO LAUNCHER INTERNALS"
                android:textColor="@color/zl_text_muted"
                android:textSize="7sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />
        </LinearLayout>

        <View
            android:id="@+id/ipc_status_dot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/dot_amber"
            android:layout_marginEnd="6dp" />
        <TextView
            android:id="@+id/tv_ipc_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disconnected"
            android:textColor="@color/zl_text_muted"
            android:textSize="10sp"
            android:layout_marginEnd="12dp" />

        <Button
            android:id="@+id/btn_ping"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="PING"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/bg_launch_btn"
            android:paddingHorizontal="12dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- ── Ping result (unchanged) ──────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_ping_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/zl_text_muted"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- ── Tab navigation bar – NOW 4 TABS ──────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/zl_bg_surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_class_explorer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CLASS"
                android:textColor="@color/zl_cyan"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:gravity="center"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_item" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/zl_bg_card" />

            <TextView
                android:id="@+id/tab_injection_console"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ INJECT"
                android:textColor="@color/zl_text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.10"
                android:gravity="center"
                android:padding="10dp"
                android:alpha="0.55"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_item" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/zl_bg_card" />

            <TextView
                android:id="@+id/tab_network_monitor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📡 NET"
                android:textColor="@color/zl_text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.10"
                android:gravity="center"
                android:padding="10dp"
                android:alpha="0.55"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_item" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/zl_bg_card" />

            <TextView
                android:id="@+id/tab_memory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MEMORY"
                android:textColor="@color/zl_text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.10"
                android:gravity="center"
                android:padding="10dp"
                android:alpha="0.55"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_item" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/zl_bg_card" />

            <!-- ── NEW: Crashes tab ────────────────────────────────────────── -->
            <TextView
                android:id="@+id/tab_crashes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💥 CRASHES"
                android:textColor="@color/zl_text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.10"
                android:gravity="center"
                android:padding="10dp"
                android:alpha="0.55"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_menu_item" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/zl_bg_card" />

    </LinearLayout>

    <!-- ── Fragment container ────────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/dev_tools_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
